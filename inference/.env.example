# Force the demo plane even if a GPU is present (handy for frontend work).
# STUDIO_DEMO=1

# Browser origins allowed to call the API (Next.js dev + preview).
STUDIO_CORS_ORIGINS=http://localhost:3000,http://localhost:3100

# Real plane only: Hugging Face token for downloading the base SDXL weights.
# Read directly by diffusers/huggingface_hub. Not needed for the demo plane.
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxx

# Optional overrides.
# STUDIO_VARIANTS=./variants.yaml
# STUDIO_LORA_DIR=./loras
# STUDIO_BASE_MODEL=stabilityai/stable-diffusion-xl-base-1.0
