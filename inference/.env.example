# Force the demo plane even if a GPU is present (handy for frontend work).
# STUDIO_DEMO=1

# Browser origins allowed to call the API (Next.js dev + preview).
STUDIO_CORS_ORIGINS=http://localhost:3000,http://localhost:3100

# Real (TensorRT) plane: where the prebuilt engine bundles live locally. In prod
# an init container syncs them here from STUDIO_ENGINE_S3_URI. Not used in demo.
STUDIO_ENGINE_DIR=./engines
STUDIO_ENGINE_S3_URI=s3://quant-studio-engine-bucket

# Optional overrides.
# STUDIO_VARIANTS=./variants.yaml
