{
    "Version": "2012-10-17",
    "Statement": [
      {
        "Sid": "EcrAuth",
        "Effect": "Allow",
        "Action": "ecr:GetAuthorizationToken",
        "Resource": "*"
      },
      {
        "Sid": "EcrPushPull",
        "Effect": "Allow",
        "Action": [
          "ecr:BatchCheckLayerAvailability",
          "ecr:InitiateLayerUpload",
          "ecr:UploadLayerPart",
          "ecr:CompleteLayerUpload",
          "ecr:PutImage",
          "ecr:BatchGetImage",
          "ecr:GetDownloadUrlForLayer"
        ],
        "Resource": [
          "arn:aws:ecr:ap-southeast-5:913488665670:repository/quantstudio-inference",
          "arn:aws:ecr:ap-southeast-5:913488665670:repository/quantstudio-web"
        ]
      }
    ]
  }